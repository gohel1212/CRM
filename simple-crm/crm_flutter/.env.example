# Prisma Database Connection URL
# Replace with your Supabase Transaction connection string (usually port 6543 for pooling)
# Example: postgresql://postgres.xxxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres"

# Secret key for JWT signing (use a long, secure random string in production)
JWT_SECRET="crm_super_secret_key_12345"
